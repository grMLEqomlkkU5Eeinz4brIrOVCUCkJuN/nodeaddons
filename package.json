{
  "name": "cppintegrations",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "build/Release",
    "src",
    "binding.gyp"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "npm run build:native && npm run build:ts",
    "build:native": "node-gyp rebuild",
    "build:ts": "tsc",
    "build:debug": "node-gyp rebuild --debug",
    "clean": "node-gyp clean && rimraf dist",
    "dev": "npm run build && nodemon dist/index.js",
    "test": "npm run build && jest",
    "lint": "eslint .",
    "format:cc": "find . -name \"*.cc\" -exec clang-format -i {} \\;",
    "format": "find . \\( -name \"*.cc\" -o -name \"*.cpp\" -o -name \"*.h\" \\) -exec clang-format -i {} \\;"
  },
  "gypfile": true,
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "node-api-headers": "^1.8.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "node-addon-api": "^8.7.0"
  }
}
